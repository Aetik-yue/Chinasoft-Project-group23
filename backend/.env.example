# ============================================================
# 环境变量配置示例（复制为 .env 后填入真实值，勿提交到 git）
# ============================================================
# 在 Windows 中设置方式：
#   方式一（推荐，永久）：系统设置 → 环境变量 → 新建用户变量
#   方式二（临时，当前终端生效）：set DEEPSEEK_API_KEY=sk-xxx
#   方式三（PowerShell）：$env:DEEPSEEK_API_KEY = "sk-xxx"
#
# 设置完后必须重启后端（mvn spring-boot:run），让新环境变量生效
# ============================================================

# ---- QQ 机器人（NapCat）----
# NapCat WebUI 里 HTTP 服务端设置的 access_token
ONEBOT_ACCESS_TOKEN=your_napcat_access_token_here

# ---- MaxKB 智能问答 ----
# MaxKB 后台应用详情页获取
MAXKB_APP_ID=your_maxkb_app_id_here
MAXKB_API_KEY=your_maxkb_api_key_here

# ---- DeepSeek 大模型 ----
# platform.deepseek.com 申请的 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
